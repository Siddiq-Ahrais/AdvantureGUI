<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<StackPane id="titlePane" xmlns:fx="http://javafx.com/fxml"
           fx:controller="pack.TitleController"
           prefWidth="1000" prefHeight="680">

    <VBox alignment="CENTER" spacing="60">
        <Label id="titleLabel" text="ADVANTURE"/>
        <Button id="startButton" text="START" onAction="#onStartClicked"/>
    </VBox>

</StackPane>
